## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
build/
bin/
obj/
out/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Visual Studio Code
.vscode/

# Rider
.idea/

# VS Code settings (optional keep if shared)
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Logs
*.log

# Runtime files
*.pid
*.seed
*.pid.lock

# OS generated files
.DS_Store
Thumbs.db

# Environment variables
.env
.env.*

# Publish output
publish/
wwwroot/lib/

# Node modules (if using frontend tools)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Coverage reports
coverage/
*.coverage
*.coveragexml

# Test results
TestResults/

# NuGet packages
*.nupkg
# Uncomment if you don't want to check in packages
# packages/

# Dotnet CLI
.dotnet/

# Azure
*.azurePubxml

# IIS Express
.vs/
.config/

# Backup & temp files
*.bak
*.tmp
*.temp

# Resharper
_ReSharper*/
*.DotSettings.user

# StyleCop
StyleCopReport.xml

# Entity Framework
Migrations/*.Designer.cs
Migrations/*.resx

# SQL Server
*.mdf
*.ldf

# Certificates
*.pfx
*.cer

# JetBrains Rider
.idea/

# Docker
docker-compose.override.yml

# Local secrets
secrets.json
appsettings.Development.json